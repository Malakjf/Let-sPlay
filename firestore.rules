rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin (case-insensitive)
    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '').toLowerCase() == 'admin';
    }

    // Helper function to check if user is organizer or admin (case-insensitive)
    function isOrganizerOrAdmin() {
      return isAuthenticated() &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '').toLowerCase() == 'admin' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '').toLowerCase() == 'organizer');
    }

    // Helper function to check if user is coach (case-insensitive)
    function isCoach() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '').toLowerCase() == 'coach';
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read user data
      allow read: if isAuthenticated();
      
      // Users can create their own profile during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can update their own profile
      // Admins can update any profile
      // Coaches can update player profiles (but not role field)
      allow update: if isOwner(userId) || 
                       isAdmin() || 
                       (isCoach() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // Matches collection
    match /matches/{matchId} {
      // Anyone authenticated can read matches
      allow read: if isAuthenticated();
      
      // Only organizers and admins can create/update/delete matches
      allow create, delete: if isOrganizerOrAdmin();
      
      // Allow updates by organizers/admins, OR by users joining/leaving
      allow update: if isOrganizerOrAdmin() || 
                   (isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'playersCount']) &&
                    (request.resource.data.playersCount == resource.data.get('playersCount', 0) + 1 || 
                     request.resource.data.playersCount == resource.data.get('playersCount', 0) - 1));

      // Allow access to player stats subcollection
      match /player_stats/{docId} {
        allow read, write: if isAuthenticated();
      }

      // Allow access to player metrics subcollection
      match /player_metrics/{docId} {
        allow read, write: if isAuthenticated();
      }

      // Players subcollection (Join/Leave tracking)
      match /players/{userId} {
        allow read: if isAuthenticated();
        // Allow join only if: User is self, Match is Open, Match is not Full
        allow create: if isAuthenticated() && request.auth.uid == userId &&
                      get(/databases/$(database)/documents/matches/$(matchId)).data.get('status', 'closed') == 'open' &&
                      get(/databases/$(database)/documents/matches/$(matchId)).data.get('playersCount', 0) < get(/databases/$(database)/documents/matches/$(matchId)).data.get('maxPlayers', 0);
        
        // Allow leave
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Fields collection
    match /fields/{fieldId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isOrganizerOrAdmin();
    }

    // Role requests collection
    match /roleRequests/{requestId} {
      allow read: if isAuthenticated() && 
                     (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Evaluations collection - role-based access control
    match /evaluations/{evaluationId} {
      // Read: Admins see all, Coaches see their own submissions, Players see their own evaluations, Organizers can read
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isCoach() && resource.data.coachId == request.auth.uid) ||
        resource.data.playerId == request.auth.uid ||
        isOrganizerOrAdmin()
      );

      // Create: Admins and Coaches can create
      allow create: if isAuthenticated() && (
        isAdmin() || isCoach()
      ) && (
        // If coach creating, ensure coachId matches auth uid
        (isAdmin() || request.resource.data.coachId == request.auth.uid)
      );

      // Update: Admins can update any. Coaches may update their own evaluations.
      allow update: if isAuthenticated() && (
        isAdmin() || (isCoach() && resource.data.coachId == request.auth.uid)
      );

      // Delete: only admins
      allow delete: if isAuthenticated() && isAdmin();
    }
  }
}
